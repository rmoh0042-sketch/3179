{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": "container",
  "height": 360,
  "data": {
    "url": "data/processed/04_purpose_by_quarter_trips.csv"
  },
  "transform": [
    {
      "calculate": "datum.trips / 1000",
      "as": "trips_million"
    }
  ],
  "title": {
    "text": "Travel purpose across quarters",
    "subtitle": "Holiday travel remained the largest share of domestic trips across 2025",
    "anchor": "start",
    "font": "Inter",
    "fontSize": 18,
    "fontWeight": 700,
    "subtitleFont": "Inter",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "color": "#1d3156",
    "subtitleColor": "#496894"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopLeft": 4,
    "cornerRadiusTopRight": 4
  },
  "encoding": {
    "x": {
      "field": "quarter",
      "type": "ordinal",
      "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"],
      "axis": {
        "title": null,
        "labelAngle": 0,
        "labelFont": "Inter",
        "labelColor": "#1d3156"
      }
    },
    "y": {
      "aggregate": "sum",
      "field": "trips_million",
      "type": "quantitative",
      "axis": {
        "title": "Trips (millions)",
        "format": ".0f",
        "labelFont": "Inter",
        "titleFont": "Inter",
        "labelColor": "#1d3156",
        "titleColor": "#1d3156",
        "gridColor": "#dce8f4"
      }
    },
    "color": {
      "field": "purpose",
      "type": "nominal",
      "scale": {
        "domain": [
          "Holiday",
          "Visiting friends and relatives",
          "Business",
          "Other"
        ],
        "range": [
          "#1d3156",
          "#496894",
          "#a4b5d1",
          "#fed6ce"
        ]
      },
      "legend": {
        "title": "Purpose",
        "orient": "bottom",
        "labelFont": "Inter",
        "titleFont": "Inter",
        "labelColor": "#1d3156",
        "titleColor": "#1d3156"
      }
    },
    "tooltip": [
      {
        "field": "quarter",
        "type": "ordinal",
        "title": "Quarter"
      },
      {
        "field": "purpose",
        "type": "nominal",
        "title": "Purpose"
      },
      {
        "field": "trips_million",
        "type": "quantitative",
        "title": "Trips (millions)",
        "format": ".1f"
      },
      {
        "field": "trips",
        "type": "quantitative",
        "title": "Trips ('000)",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domainColor": "#a4b5d1",
      "tickColor": "#a4b5d1"
    }
  }
}