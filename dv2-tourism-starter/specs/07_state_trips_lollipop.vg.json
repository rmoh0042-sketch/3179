{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": "container",
  "height": 340,
  "data": {
    "url": "data/processed/07_state_december_trips.csv"
  },
  "transform": [
    {
      "calculate": "datum.trips / 1000",
      "as": "trips_million"
    },
    {
      "calculate": "format(datum.trips / 1000, '.1f') + 'M'",
      "as": "trips_label"
    },
    {
      "calculate": "datum.state == 'New South Wales' ? 'NSW' : datum.state == 'Australian Capital Territory' ? 'ACT' : datum.state == 'Northern Territory' ? 'NT' : datum.state",
      "as": "state_short"
    }
  ],
  "title": {
    "text": "Top states by domestic trips",
    "subtitle": "New South Wales recorded the highest trip volume in December 2025",
    "anchor": "start",
    "font": "Inter",
    "fontSize": 18,
    "fontWeight": 700,
    "subtitleFont": "Inter",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "color": "#1d3156",
    "subtitleColor": "#496894"
  },
  "layer": [
    {
  "mark": {
    "type": "bar",
    "height": 3,
    "color": "#fed6ce"
  },
      "encoding": {
        "y": {
          "field": "state_short",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "trips_million",
          "type": "quantitative",
          "scale": {
            "zero": true
          }
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 260,
        "color": "#496894",
        "stroke": "#ffffff",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "state_short",
          "type": "nominal",
          "sort": "-x",
          "axis": {
            "title": null,
            "labelFont": "Inter",
            "labelColor": "#1d3156",
            "labelLimit": 170
          }
        },
        "x": {
          "field": "trips_million",
          "type": "quantitative",
          "scale": {
            "zero": true
          },
          "axis": {
            "title": "Trips (millions)",
            "format": ".0f",
            "labelFont": "Inter",
            "titleFont": "Inter",
            "labelColor": "#1d3156",
            "titleColor": "#1d3156",
            "gridColor": "#dce8f4"
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "trips_million",
            "type": "quantitative",
            "title": "Trips (millions)",
            "format": ".1f"
          },
          {
            "field": "trips",
            "type": "quantitative",
            "title": "Trips ('000)",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 12,
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": 700,
        "color": "#1d3156"
      },
      "encoding": {
        "y": {
          "field": "state_short",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "trips_million",
          "type": "quantitative"
        },
        "text": {
          "field": "trips_label"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domainColor": "#a4b5d1",
      "tickColor": "#a4b5d1"
    }
  }
}