{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": "container",
  "height": 300,
  "data": {
    "url": "data/processed/01_total_trips_by_quarter.csv"
  },
  "title": {
    "text": "Total domestic trips over 2025",
    "subtitle": "Trips increased from 94.1M in March to 100.3M in December",
    "anchor": "start",
    "font": "Inter",
    "fontSize": 18,
    "fontWeight": 700,
    "subtitleFont": "Inter",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "color": "#1d3156",
    "subtitleColor": "#496894"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": false,
        "strokeWidth": 4,
        "color": "#496894"
      },
      "encoding": {
        "x": {
          "field": "quarter",
          "type": "ordinal",
          "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"],
          "axis": {
            "title": null,
            "labelAngle": 0,
            "labelFont": "Inter",
            "labelColor": "#1d3156"
          }
        },
        "y": {
          "field": "total_trips",
          "type": "quantitative",
          "scale": {"zero": true},
          "axis": {
            "title": "Trips ('000)",
            "format": "~s",
            "labelFont": "Inter",
            "titleFont": "Inter",
            "labelColor": "#1d3156",
            "titleColor": "#1d3156",
            "gridColor": "#dce8f4"
          }
        },
        "tooltip": [
          {"field": "quarter", "type": "ordinal", "title": "Quarter"},
          {"field": "total_trips", "type": "quantitative", "title": "Trips ('000)", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 120, "color": "#1d3156", "stroke": "#f7fbff", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "quarter", "type": "ordinal", "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"]},
        "y": {"field": "total_trips", "type": "quantitative", "scale": {"zero": false}},
        "tooltip": [
          {"field": "quarter", "type": "ordinal", "title": "Quarter"},
          {"field": "total_trips", "type": "quantitative", "title": "Trips ('000)", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{"quarter": "Dec 2025", "total_trips": 100280, "label": "100.3M trips"}]},
      "mark": {"type": "text", "align": "left", "baseline": "middle", "dx": -25, "dy": -17
      , "font": "Inter", "fontWeight": 700, "fontSize": 12, "color": "#1d3156"},
      "encoding": {
        "x": {"field": "quarter", "type": "ordinal", "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"]},
        "y": {"field": "total_trips", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {"domainColor": "#a4b5d1", "tickColor": "#a4b5d1"}
  }
}
