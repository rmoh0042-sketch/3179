{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "width": "container",
  "height": 300,
  "data": {
    "url": "data/processed/02_total_spend_by_quarter.csv"
  },
  "transform": [
    {
      "calculate": "datum.total_spend_million / 1000",
      "as": "spend_billion"
    }
  ],
  "title": {
    "text": "Total domestic travel spend over 2025",
    "subtitle": "Spending dipped in June, then recovered in December",
    "anchor": "start",
    "font": "Inter",
    "fontSize": 18,
    "fontWeight": 700,
    "subtitleFont": "Inter",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "color": "#1d3156",
    "subtitleColor": "#496894"
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {
          "color": "#496894",
          "strokeWidth": 3
        },
        "point": false,
        "color": "#a4b5d1",
        "opacity": 0.45
      },
      "encoding": {
        "x": {
          "field": "quarter",
          "type": "ordinal",
          "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"],
          "axis": {
            "title": null,
            "labelAngle": 0,
            "labelFont": "Inter",
            "labelColor": "#1d3156"
          }
        },
        "y": {
          "field": "spend_billion",
          "type": "quantitative",
          "scale": {
            "zero": true
          },
          "axis": {
            "title": "Spend ($B)",
            "format": ".1f",
            "labelFont": "Inter",
            "titleFont": "Inter",
            "labelColor": "#1d3156",
            "titleColor": "#1d3156",
            "gridColor": "#dce8f4"
          }
        },
        "tooltip": [
          {
            "field": "quarter",
            "type": "ordinal",
            "title": "Quarter"
          },
          {
            "field": "spend_billion",
            "type": "quantitative",
            "title": "Spend ($B)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "color": "#496894",
        "stroke": "#f7fbff",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "quarter",
          "type": "ordinal",
          "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"]
        },
        "y": {
          "field": "spend_billion",
          "type": "quantitative",
          "scale": {
            "zero": true
          }
        },
        "tooltip": [
          {
            "field": "quarter",
            "type": "ordinal",
            "title": "Quarter"
          },
          {
            "field": "spend_billion",
            "type": "quantitative",
            "title": "Spend ($B)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "quarter": "Dec 2025",
            "spend_billion": 39.993,
            "label": "40.0 billion"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": -45,
        "dy": -14,
        "font": "Inter",
        "fontWeight": 700,
        "fontSize": 12,
        "color": "#1d3156"
      },
      "encoding": {
        "x": {
          "field": "quarter",
          "type": "ordinal",
          "sort": ["Mar 2025", "Jun 2025", "Sep 2025", "Dec 2025"]
        },
        "y": {
          "field": "spend_billion",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domainColor": "#a4b5d1",
      "tickColor": "#a4b5d1"
    }
  }
}